{
  "name": "jira-mcp-agents",
  "version": "1.0.0",
  "description": "AI agents for automated repository maintenance",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "security": "tsx src/agents/security-agent.ts",
    "bug-fix": "tsx src/agents/bug-fix-agent.ts",
    "pr-review": "tsx src/agents/pr-review-agent.ts"
  },
  "dependencies": {
    "ai": "^6.0.175",
    "@ai-sdk/google": "^3.0.65",
    "@ai-sdk/groq": "^3.0.36",
    "@ai-sdk/deepseek": "^2.0.30",
    "@ai-sdk/openai": "^3.0.62",
    "@ai-sdk/openai-compatible": "^2.0.42",
    "@ai-sdk/anthropic": "^3.0.75",
    "@ai-sdk/mistral": "^3.0.31",
    "@ai-sdk/perplexity": "^3.0.30",
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "@octokit/rest": "^22.0.1",
    "zod": "^4.3.6",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "tsx": "^4.19.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
